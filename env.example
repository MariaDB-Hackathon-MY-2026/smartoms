# ==============================================================
# SMARTOMS — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
#
# Usage:
#   cp .env.example .env
# ==============================================================


# --------------------------------------------------------------
# DATABASE
# --------------------------------------------------------------

# Full SQLAlchemy connection string (used by Python backend)
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/oms

# Individual DB credentials (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=oms


# --------------------------------------------------------------
# BACKEND (FastAPI)
# --------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000


# --------------------------------------------------------------
# FRONTEND (Vite/React)
# --------------------------------------------------------------
# All frontend variables MUST be prefixed with VITE_
# These are read via import.meta.env.VITE_*

VITE_API_URL=http://localhost:8000/api